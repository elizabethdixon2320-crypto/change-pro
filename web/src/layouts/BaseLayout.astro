---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Change Pro · 让改变持续发生",
  description = "Change Pro 是面向城市高密度人群的健身生活方式品牌。从训练空间到生活方式生态。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/logo-black.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <div class="qr-modal" id="qr-modal" aria-hidden="true" role="dialog">
      <div class="qr-modal__backdrop" data-qr-close></div>
      <div class="qr-modal__panel">
        <button type="button" class="qr-modal__close" aria-label="关闭" data-qr-close>×</button>
        <h3 class="qr-modal__title" id="qr-modal-title">扫码下载 Change App</h3>
        <p class="qr-modal__desc" id="qr-modal-desc">使用手机相机或微信扫一扫</p>
        <img class="qr-modal__img" id="qr-modal-img" src="/assets/qr-app.png" alt="QR" />
      </div>
    </div>

    <button type="button" id="float-service" class="float-service" aria-label="联系企微客服" style="position:fixed; right:20px; bottom:20px; z-index:90;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
      <span class="float-service__text">客服</span>
    </button>
    <style>
      .qr-modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; visibility: hidden; transition: opacity 220ms var(--ease), visibility 220ms; }
      .qr-modal.is-open { opacity: 1; pointer-events: auto; visibility: visible; }
      .qr-modal__backdrop { position: absolute; inset: 0; background: rgba(17,17,17,0.65); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
      .qr-modal__panel { position: relative; background: #fff; border-radius: 20px; padding: 32px 28px 28px; max-width: 320px; width: calc(100% - 40px); box-shadow: 0 24px 60px rgba(0,0,0,0.25); text-align: center; }
      .qr-modal__close { position: absolute; top: 8px; right: 12px; background: transparent; border: none; font-size: 28px; line-height: 1; color: var(--gray); cursor: pointer; padding: 4px 8px; }
      .qr-modal__title { font-family: var(--font-text); font-weight: 900; font-size: 18px; color: var(--ink); margin: 0 0 6px; }
      .qr-modal__desc { font-size: 13px; color: var(--gray-soft); margin: 0 0 18px; }
      .qr-modal__img { width: 220px; height: 220px; display: block; margin: 0 auto; border-radius: 12px; }
      .float-service { position: fixed; right: 20px; bottom: 20px; z-index: 90; display: inline-flex; align-items: center; gap: 6px; padding: 10px 16px 10px 14px; background: var(--orange); color: #fff; border: none; border-radius: 999px; font-family: var(--font-display); font-weight: 700; font-size: 13px; letter-spacing: 0.1em; cursor: pointer; box-shadow: 0 10px 28px rgba(248,133,0,0.35), 0 2px 6px rgba(0,0,0,0.12); transition: transform 180ms var(--ease), box-shadow 180ms var(--ease); }
      .float-service:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(248,133,0,0.45), 0 2px 6px rgba(0,0,0,0.12); }
      .float-service svg { display: block; }
      @media (max-width: 640px) { .float-service { right: 14px; bottom: 14px; padding: 12px; border-radius: 50%; } .float-service__text { display: none; } }
    </style>

    <script is:inline>
      // Reveal on scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: "0px 0px -10% 0px" }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      const qrModal = document.getElementById("qr-modal");
      const qrImg = document.getElementById("qr-modal-img");
      const qrTitle = document.getElementById("qr-modal-title");
      const qrDesc = document.getElementById("qr-modal-desc");
      const qrPresets = {
        app:    { src: "/assets/qr-app.png",    title: "扫码下载 Change App",      desc: "使用手机相机或微信扫一扫" },
        wechat: { src: "/assets/qr-wechat.png", title: "联系 Change Pro 企微客服", desc: "扫一扫添加专属客服企业微信" },
      };
      function openQR(type) {
        const p = qrPresets[type] || qrPresets.app;
        if (qrImg) qrImg.src = p.src;
        if (qrTitle) qrTitle.textContent = p.title;
        if (qrDesc) qrDesc.textContent = p.desc;
        qrModal && qrModal.classList.add("is-open");
        qrModal && qrModal.setAttribute("aria-hidden", "false");
      }
      function closeQR() { qrModal && qrModal.classList.remove("is-open"); qrModal && qrModal.setAttribute("aria-hidden", "true"); }
      document.querySelectorAll("[data-qr-app]").forEach((el) => { el.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); openQR("app"); }); });
      const floatBtn = document.getElementById("float-service");
      if (floatBtn) floatBtn.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); openQR("wechat"); });
      document.querySelectorAll("[data-qr-close]").forEach((el) => el.addEventListener("click", (e) => { e.preventDefault(); closeQR(); }));
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeQR(); });

      // Count-up animation for stats
      (function() {
        const countEls = document.querySelectorAll('[data-count]');
        if (!countEls.length) return;

        const duration = 1600;
        const easeOutQuart = (t) => 1 - Math.pow(1 - t, 4);

        function animateCount(el) {
          const raw = el.getAttribute('data-count');
          const cleanRaw = String(raw).replace(/,/g, '');
          const match = cleanRaw.match(/^(\d+)(.*)$/);
          if (!match) return;
          const targetNum = parseInt(match[1], 10);
          const startTime = performance.now();

          // Find the span that holds the number
          const span = el.querySelector('span');
          // Preserve any non-digit suffix inside the span (e.g. "万")
          let spanSuffix = '';
          if (span) {
            const spanText = (span.textContent || '').replace(/,/g, '');
            const spanMatch = spanText.match(/^\d+(.*)$/);
            if (spanMatch) spanSuffix = spanMatch[1] || '';
          }

          function step(now) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = easeOutQuart(progress);
            const current = Math.round(eased * targetNum);
            const formatted = current.toLocaleString('en-US');
            const fullText = formatted + spanSuffix;

            if (span) {
              span.textContent = fullText;
            } else {
              const em = el.querySelector('em');
              if (em && el.childNodes.length >= 2) {
                el.childNodes[0].nodeValue = fullText;
              } else {
                el.textContent = fullText;
              }
            }

            if (progress < 1) {
              requestAnimationFrame(step);
            } else {
              const finalText = targetNum.toLocaleString('en-US') + spanSuffix;
              if (span) {
                span.textContent = finalText;
              } else {
                const em = el.querySelector('em');
                if (em && el.childNodes.length >= 2) {
                  el.childNodes[0].nodeValue = finalText;
                } else {
                  el.textContent = finalText;
                }
              }
            }
          }
          requestAnimationFrame(step);
        }

        const countIo = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              animateCount(e.target);
              countIo.unobserve(e.target);
            }
          }
        }, { threshold: 0.3 });

        countEls.forEach((el) => countIo.observe(el));
      })();
    </script>
  </body>
</html>
