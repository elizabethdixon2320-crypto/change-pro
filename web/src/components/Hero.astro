---
---
<section class="hero" id="hero">
  <div class="hero__inner container">
    <div class="hero__eyebrow reveal">
      <span>CHANGE PRO</span>
      <span class="dot"></span>
      <span>BRAND 2026</span>
    </div>

    <h1 class="hero__display reveal">
      <span class="hero__word">CHANGE</span>
      <span class="hero__word hero__word--out">PRO</span>
    </h1>

    <div class="hero__meta reveal">
      <p class="hero__cn">让改变持续发生</p>
      <p class="hero__en">Change is a Habit.</p>
    </div>

    <a href="#vision" class="hero__scroll reveal" aria-label="Scroll to content">
      <span>SCROLL</span>
      <svg width="20" height="28" viewBox="0 0 20 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="1" width="18" height="26" rx="9" stroke="currentColor" stroke-width="1.5"/>
        <circle class="scroll-dot" cx="10" cy="9" r="2.5" fill="currentColor"/>
      </svg>
    </a>

  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--white);
    padding-top: 68px; /* nav height */
    padding-block: var(--space-9);
  }
  .hero__inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--fs-eyebrow);
    font-weight: 700;
    letter-spacing: var(--ls-wide);
    color: var(--gray);
  }
  .hero__eyebrow .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
    display: inline-block;
  }

  .hero__display {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--fs-mega);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .hero__word {
    display: block;
  }
  .hero__word--out {
    color: transparent;
    -webkit-text-stroke: 2px var(--ink);
    text-stroke: 2px var(--ink);
  }

  .hero__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .hero__cn {
    font-family: var(--font-text);
    font-weight: 900;
    font-size: clamp(22px, 2.6vw, 36px);
    line-height: 1.2;
    margin: 0;
    color: var(--ink);
  }
  .hero__en {
    font-family: var(--font-display);
    font-size: var(--fs-lead);
    color: var(--gray);
    margin: 0;
  }

  .hero__foot {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-top: var(--space-7);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
  }

  .hero__stats {
    display: flex;
    gap: var(--space-9);
    flex-wrap: wrap;
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .hero__stat strong {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .hero__stat em {
    font-style: normal;
    color: var(--orange);
  }
  .hero__stat span {
    font-family: var(--font-display);
    font-size: var(--fs-eyebrow);
    font-weight: 700;
    letter-spacing: var(--ls-wide);
    color: var(--gray);
    text-transform: uppercase;
  }
  .hero__stat--accent strong { color: var(--orange); }
  .hero__stat--accent em { color: var(--orange); }

  .hero__scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-size: var(--fs-caption);
    font-weight: 700;
    letter-spacing: var(--ls-wide);
    color: var(--gray-soft);
    align-self: flex-start;
    margin-top: var(--space-7);
    transition: color 220ms var(--ease), transform 220ms var(--ease);
    animation: scrollBounce 2s ease-in-out infinite;
  }
  .hero__scroll:hover {
    color: var(--orange);
    transform: translateY(4px);
  }
  .hero__scroll svg { color: var(--gray-soft); transition: color 220ms var(--ease); }
  .hero__scroll:hover svg { color: var(--orange); }
  .scroll-dot {
    animation: scrollDot 2s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @keyframes scrollDot {
    0%, 100% { opacity: 1; transform: translateY(0); }
    50% { opacity: 0.4; transform: translateY(6px); }
  }

  @media (max-width: 640px) {
    .hero__inner { gap: var(--space-5); }
    .hero__scroll { margin-top: var(--space-6); }
  }
</style>
