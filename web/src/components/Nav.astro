---
const links = [
  { href: "#vision",    label: "VISION",    cn: "品牌愿景" },
  { href: "#system",    label: "SYSTEM",    cn: "运营体系" },
  { href: "#network",   label: "NETWORK",   cn: "门店网络" },
  { href: "#partners",  label: "PARTNERS",  cn: "合作伙伴" },
  { href: "#community", label: "COMMUNITY", cn: "会员社群" },
  { href: "#digital",   label: "DIGITAL",   cn: "数字生态" },
  { href: "#retail",    label: "RETAIL",    cn: "零售消费" },
  { href: "#future",    label: "FUTURE",    cn: "未来规划" },
];
---

<header class="nav">
  <div class="nav__inner container">
    <a class="nav__brand" href="#hero" aria-label="Change Pro">
      <img src="/assets/logo-black.png" alt="Change Pro" />
    </a>
    <nav class="nav__links" aria-label="Sections">
      {links.map((l) => (
        <a href={l.href}>
          <span class="nav__cn">{l.cn}</span>
          <span class="nav__en">{l.label}</span>
        </a>
      ))}
    </nav>
    <a class="btn btn--primary nav__cta" href="https://changepro.vip" target="_blank" rel="noopener noreferrer">APP</a>

    <!-- Mobile hamburger -->
    <button class="nav__hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
    </button>
  </div>
</header>

<!-- Mobile overlay menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu__header">
    <a class="mobile-menu__brand" href="#hero" aria-label="Change Pro">
      <img src="/assets/logo-black.png" alt="Change Pro" />
    </a>
    <button class="mobile-menu__close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav class="mobile-menu__nav" aria-label="Mobile sections">
    {links.map((l, i) => (
      <a href={l.href} class="mobile-menu__link" style={`--delay: ${i * 60}ms`}>
        <span class="mobile-menu__cn">{l.cn}</span>
        <span class="mobile-menu__en">{l.label}</span>
      </a>
    ))}
  </nav>
  <a class="btn btn--primary mobile-menu__cta" href="https://changepro.vip" target="_blank" rel="noopener noreferrer">下载 Change App</a>
</div>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 80;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: saturate(180%) blur(18px);
    -webkit-backdrop-filter: saturate(180%) blur(18px);
    border-bottom: 1px solid var(--hairline);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    height: 64px;
  }
  .nav__brand img {
    height: 22px;
    width: auto;
    display: block;
  }
  @media (max-width: 640px) {
    .nav__inner { height: 56px; }
    .nav__brand img { height: 18px; }
    .nav__cta { padding: 8px 14px; font-size: 11px; }
  }
  .nav__links {
    display: flex;
    gap: var(--space-5);
    font-family: var(--font-display);
  }
  .nav__links a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    color: var(--gray);
    transition: color 180ms var(--ease);
    line-height: 1.2;
  }
  .nav__links a:hover { color: var(--orange); }
  .nav__en {
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: 0.15em;
    color: var(--orange);
  }
  .nav__cn {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    opacity: 0.8;
  }
  .nav__cta { padding: 10px 20px; }

  /* Hamburger button */
  .nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 90;
  }
  .hamburger__line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: all 250ms var(--ease);
    transform-origin: center;
  }

  /* Mobile menu overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 85;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(180%) blur(24px);
    -webkit-backdrop-filter: saturate(180%) blur(24px);
    display: flex;
    flex-direction: column;
    padding: var(--space-5) var(--gutter) var(--space-8);
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity 300ms var(--ease), visibility 300ms;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    max-height: 100vh;
  }
  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }
  .mobile-menu__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--hairline);
    padding-bottom: var(--space-4);
  }
  .mobile-menu__brand img { height: 18px; }
  .mobile-menu__close {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    background: transparent;
    border: none;
    color: var(--ink);
    cursor: pointer;
  }
  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
    justify-content: center;
  }
  .mobile-menu__link {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: var(--ls-wide);
    color: var(--ink);
    text-transform: uppercase;
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 350ms var(--ease), transform 350ms var(--ease), color 180ms;
    transition-delay: var(--delay, 0ms);
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    line-height: 1.2;
  }
  .mobile-menu.is-open .mobile-menu__link {
    opacity: 1;
    transform: translateX(0);
  }
  .mobile-menu__link:hover { color: var(--orange); }
  .mobile-menu__en {
    font-size: clamp(24px, 5vw, 40px);
    color: var(--orange);
    line-height: 1;
    font-weight: 400;
    letter-spacing: 0.15em;
  }
  .mobile-menu__cn {
    font-size: 14px;
    font-weight: 500;
    opacity: 0.8;
    text-transform: none;
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .mobile-menu__cta {
    margin-top: var(--space-2);
    align-self: flex-start;
    padding: 10px 20px;
    font-size: var(--fs-small);
  }

  @media (max-width: 1080px) {
    .nav__links { display: none; }
    .nav__hamburger { display: flex; }
  }
  @media (max-width: 560px) {
    .nav__cta { display: none; }
  }
</style>

<script is:inline>
  (function() {
    const hamburger = document.querySelector('.nav__hamburger');
    const mobileMenu = document.querySelector('.mobile-menu');
    const closeBtn = document.querySelector('.mobile-menu__close');
    const menuLinks = document.querySelectorAll('.mobile-menu__link');
    const menuBrand = document.querySelector('.mobile-menu__brand');
    const menuCta = document.querySelector('.mobile-menu__cta');

    function openMenu() {
      mobileMenu.classList.add('is-open');
      hamburger.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      mobileMenu.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    if (hamburger) hamburger.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    if (menuBrand) menuBrand.addEventListener('click', closeMenu);
    if (menuCta) menuCta.addEventListener('click', closeMenu);

    menuLinks.forEach(function(link) {
      link.addEventListener('click', closeMenu);
    });

    // Close on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && mobileMenu.classList.contains('is-open')) {
        closeMenu();
      }
    });
  })();
</script>
