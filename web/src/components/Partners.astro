---
const partners = [
  { src: "/assets/content/partners/lifefitness.png",    name: "Life Fitness" },
  { src: "/assets/content/partners/hammerstrength.png", name: "Hammer Strength" },
  { src: "/assets/content/partners/ELEIKO.png",         name: "Eleiko" },
  { src: "/assets/content/partners/stairmaster.png",    name: "StairMaster" },
  { src: "/assets/content/partners/ua-logo-bg.png",     name: "Under Armour" },
  { src: "/assets/content/partners/诺德士.png",         name: "Nautilus" },
  { src: "/assets/content/partners/奥力来.png",         name: "Orior" },
  { src: "/assets/content/partners/鹰牌.png",           name: "Yingpai" },
  { src: "/assets/content/partners/資產 1shakesphere.png", name: "ShakeSphere" },
  { src: "/assets/content/partners/資產 1wonderlab.png",   name: "WonderLab" },
  { src: "/assets/content/partners/資產 5monster.png",     name: "Monster" },
  { src: "/assets/content/partners/可口可乐.png",       name: "Coca-Cola" },
  { src: "/assets/content/partners/农夫山泉.png",       name: "Nongfu Spring" },
  { src: "/assets/content/partners/吨吨 bottled joy.png", name: "Bottled Joy" },
];

const cupStats = [
  { big: "8", tag: "IFBB PRO CARDS",   cn: "职业卡发放" },
  { big: "3", tag: "OLYMPIA",          cn: "奥赛资格" },
  { big: "1600万+", tag: "DOUYIN VIEWS", cn: "抖音累计播放" },
];

// 首排 3 张 (视觉主图 · 三栏大图)
const momentsTop = ["IMG_5181.jpg", "IMG_5221.jpg", "IMG_5321.jpg"];
// 下两排 · 每排 4 张
const momentsRest = [
  "IMG_2931.jpg", "IMG_2952.jpg", "IMG_2963.jpg", "IMG_2978.jpg",
  "IMG_3005.jpg", "IMG_4045.jpg", "IMG_4081.jpg", "IMG_4113.jpg",
];
---

<section class="partners section" id="partners">
  <div class="container">
    <div class="p__head reveal">
      <div class="eyebrow">04 / PARTNERS</div>
      <h2 class="section-title-cn">
        覆盖运动、营养、设备的 <br/>
        <span class="accent">核心品牌网络</span>
      </h2>
      <p class="lead">从器械到补剂，Change Pro 与全球顶级训练生态深度合作。</p>
    </div>

    <div class="p__logos">
      {partners.map((p) => (
        <div class="logo reveal">
          <img src={p.src} alt={p.name} loading="lazy"/>
        </div>
      ))}
    </div>

    <!-- Change Cup -->
    <div class="cup-head reveal">
      <div class="eyebrow eyebrow--orange">04 / CHANGE CUP</div>
      <h3 class="cup-title">国内最具影响力的<br/>职业健美赛事之一</h3>
      <p class="lead">Change 杯不是赞助，是品牌自己的 IP。每一届都在持续放大 Change Pro 的外部声量。</p>
    </div>

    <div class="cup-stats">
      {cupStats.map((s, i) => (
        <div class="cstat reveal" style={`--delay: ${i * 80}ms`}>
          <div class="cstat__big">{s.big}</div>
          <div class="cstat__tag">{s.tag}</div>
          <div class="cstat__cn">{s.cn}</div>
        </div>
      ))}
    </div>

    <div class="cup-moments-label eyebrow reveal">CHANGE CUP · COMPETITION MOMENTS</div>
  </div>

  <div class="container">
    <div class="cup-top reveal">
      {momentsTop.map((m, i) => (
        <figure class="mcard" style={`--delay: ${i * 50}ms`}>
          <img src={`/assets/content/competition/${m}`} alt={`Change Cup top ${i + 1}`} loading="lazy"/>
        </figure>
      ))}
    </div>
    <div class="cup-rest reveal">
      {momentsRest.map((m, i) => (
        <figure class="mcard" style={`--delay: ${i * 40}ms`}>
          <img src={`/assets/content/competition/${m}`} alt={`Change Cup moment ${i + 1}`} loading="lazy"/>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .p__head { max-width: 980px; margin-bottom: var(--space-9); }
  .p__head .section-title-cn { margin-block: var(--space-5) var(--space-6); }
  .p__head .accent { color: var(--orange); }

  /* 深灰 #313131 面板 + 内嵌白色 logo 卡片, 保证任意颜色 logo 都清晰可读 */
  .p__logos {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    padding: 1px;
    margin-bottom: var(--space-10);
    background: #313131;
  }
  .logo {
    aspect-ratio: 5 / 3;
    display: grid; place-items: center;
    padding: var(--space-5);
    background: var(--white);
    transition: background 200ms var(--ease);
  }
  .logo:hover { background: var(--off-white); }
  .logo img {
    max-width: 80%; max-height: 56px;
    object-fit: contain;
    transition: transform 220ms var(--ease);
  }
  .logo:hover img { transform: scale(1.04); }
  .logo:nth-child(7n) { border-right: 0; }
  .logo:nth-last-child(-n+7) { border-bottom: 0; }

  /* Cup */
  .cup-head { max-width: 780px; margin-bottom: var(--space-8); }
  .cup-title {
    font-family: var(--font-text); font-weight: 900;
    font-size: clamp(32px, 4vw, 64px); line-height: 1.2;
    margin: var(--space-4) 0 var(--space-5) 0; color: var(--ink);
  }
  .cup-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    padding-block: var(--space-8);
    border-block: 1px solid var(--hairline);
    margin-bottom: var(--space-8);
  }
  .cstat { transition-delay: var(--delay, 0ms); }
  .cstat__big {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(44px, 5vw, 80px); line-height: 1;
    color: var(--orange); letter-spacing: -0.04em;
    margin-bottom: var(--space-4);
    white-space: nowrap;
    word-break: keep-all;
  }
  .cstat__tag {
    font-family: var(--font-display); font-size: var(--fs-eyebrow);
    font-weight: 700; letter-spacing: var(--ls-wide);
    color: var(--gray); margin-bottom: 4px;
  }
  .cstat__cn { font-family: var(--font-text); font-weight: 900; font-size: 16px; color: var(--ink); }

  .cup-moments-label { margin-bottom: var(--space-5); }

  /* 赛事瞬间 · 首排 3 张主图 + 下方 2×4 网格 */
  .cup-top {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .cup-rest {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  .mcard {
    margin: 0;
    overflow: hidden;
    background: var(--off-white);
    transition-delay: var(--delay, 0ms);
  }
  .mcard img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 500ms var(--ease);
  }
  .mcard:hover img { transform: scale(1.02); }

  @media (max-width: 1200px) {
    .p__logos { grid-template-columns: repeat(5, 1fr); }
  }
  @media (max-width: 900px) {
    .p__logos { grid-template-columns: repeat(3, 1fr); }
    .cup-stats { grid-template-columns: repeat(2, 1fr); }
    .cup-top { grid-template-columns: 1fr; }
    .cup-rest { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .p__logos { grid-template-columns: repeat(2, 1fr); }
    .logo { padding: var(--space-4); }
    .cup-stats { grid-template-columns: 1fr; gap: var(--space-5); padding-block: var(--space-6); }
    .cstat__big { font-size: 44px; }
    .cup-rest { grid-template-columns: 1fr; }
  }
</style>
