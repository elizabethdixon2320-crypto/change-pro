---
const adults = [
  "/assets/content/members/IMG_4888.JPG",
  "/assets/content/members/member-water.png",
];
const youth = [
  "/assets/content/members/youth-training-1.png",
  "/assets/content/members/youth-training-3.png",
  "/assets/content/members/youth-training-rugby.png",
];
---

<section class="comm section section--off" id="community">
  <div class="container">
    <div class="c__head reveal">
      <div class="eyebrow">05 / MEMBERS · COMMUNITY</div>
      <h2 class="section-title-cn">
        品牌力写在每一位会员的 <br/>
        <span class="accent">训练日常里</span>
      </h2>
      <p class="lead">从成年会员到青训家庭，Change Pro 正在从训练品牌走向成长型社群。</p>
    </div>

    <div class="c__adults-images reveal">
      <div class="c__row c__row--adults-head">
        {adults.map((src) => (
          <figure class="c__img"><img src={src} alt="成年会员" loading="lazy"/></figure>
        ))}
      </div>
    </div>

    <div class="c__layout">
      <div class="c__youth reveal">
        <div class="eyebrow eyebrow--orange">YOUTH TRAINING</div>
        <div class="c__big" data-count="300+">
          <span>300</span><em>+</em>
        </div>
        <h3 class="c__title">青训 · 成长型社群</h3>
        <p class="c__desc">把品牌从个人训练延展到家庭运动、青少年成长与线下社群活动；青训稳定人群已达 300+。</p>
      </div>

      <div class="c__images reveal">
        <div class="c__row c__row--adults">
          <figure class="c__img"><img src={youth[0]} alt="青训家庭" loading="lazy"/></figure>
          <figure class="c__img"><img src={youth[1]} alt="青训家庭" loading="lazy"/></figure>
        </div>
        <div class="c__row c__row--youth">
          <figure class="c__img"><img src={youth[2]} alt="青训家庭" loading="lazy"/></figure>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .c__head { max-width: 980px; margin-bottom: var(--space-9); }
  .c__head .section-title-cn { margin-block: var(--space-5) var(--space-6); }
  .c__head .accent { color: var(--orange); }

  .c__layout {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-8);
    align-items: start;
  }
  .c__youth { padding-top: var(--space-5); }
  .c__big {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(96px, 12vw, 200px); line-height: 0.95;
    color: var(--ink); letter-spacing: -0.04em;
    margin-block: var(--space-5) var(--space-5);
  }
  .c__big em { font-style: normal; color: var(--orange); }
  .c__title {
    font-family: var(--font-text); font-weight: 900;
    font-size: clamp(22px, 2vw, 28px); color: var(--ink);
    margin: 0 0 var(--space-4) 0;
  }
  .c__desc { color: var(--gray); font-size: var(--fs-body); line-height: 1.75; margin: 0; max-width: 420px; }

  .c__images { display: flex; flex-direction: column; gap: var(--space-4); }
  .c__row { display: grid; gap: var(--space-4); align-items: start; }
  .c__row--adults { grid-template-columns: 1fr 1fr; }
  .c__row--youth  { grid-template-columns: 1fr; }
  .c__row--adults-head { grid-template-columns: 1fr 1fr; margin-bottom: var(--space-8); }
  .c__img { margin: 0; width: 100%; }
  .c__img img { width: 100%; height: auto; display: block; }

  @media (max-width: 900px) {
    .c__layout { grid-template-columns: 1fr; }
    .c__desc { max-width: none; }
  }
</style>
